# Questify Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.
#
# Required variables must be set before the server will start.
# Optional variables fall back to the listed defaults.

# ─────────────────────────────────────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development            # development | test | production
PORT=8000                       # HTTP port (Railway/Render inject this automatically)

# ─────────────────────────────────────────────────────────────────────────────
# MONGODB  (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Node.js
# Replace <username>, <password>, and use your cluster URL.

MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/questify?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────────────────
# JWT  (REQUIRED)
# ─────────────────────────────────────────────────────────────────────────────
# Generate secrets with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Run the command twice — once per secret. Minimum length: 32 characters.

JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRES_IN=7d               # access token TTL  (e.g. 1h, 7d, 30d)

JWT_REFRESH_SECRET=replace_with_a_different_64_char_random_hex_string
JWT_REFRESH_EXPIRES_IN=30d      # refresh token TTL

# ─────────────────────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production set this to your deployed frontend URL.

ALLOWED_ORIGINS=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────

RATE_LIMIT_WINDOW_MS=900000     # window length in ms  (default: 15 minutes)
RATE_LIMIT_MAX=100              # max requests per IP per window

# ─────────────────────────────────────────────────────────────────────────────
# PASSWORD HASHING
# ─────────────────────────────────────────────────────────────────────────────
# Cost factor for bcrypt. Range 10–15. Higher = slower but more secure.
# 12 is the recommended production default.

BCRYPT_ROUNDS=12

# ─────────────────────────────────────────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────────────────────────────────────────
# Morgan format: combined | dev | short | tiny
# Use "combined" in production (Apache-style, suitable for log aggregators).
# Use "dev" locally (coloured, concise).

LOG_FORMAT=dev

# ─────────────────────────────────────────────────────────────────────────────
# APP URL
# ─────────────────────────────────────────────────────────────────────────────
# Base URL of the frontend app. Used for constructing links in API responses.

APP_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# EMAIL / SMTP  (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Email is NOT required for any core auth or enrolment flow.
# Admin-created users receive a tempPassword in the API response body only.
# Leave all SMTP_ fields blank to disable email entirely.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false               # true for port 465, false for 587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@questify.app

# ─────────────────────────────────────────────────────────────────────────────
# CLERK  (optional)
# ─────────────────────────────────────────────────────────────────────────────
# Required only if you want admin user-creation to sync with Clerk.
# Get from: Clerk Dashboard → API Keys → Secret key
# Leave blank to disable Clerk sync — the API works without it.

CLERK_SECRET_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# API DOCS
# ─────────────────────────────────────────────────────────────────────────────
# Swagger UI is always enabled in development.
# In production it is disabled unless this is explicitly set to "true".
# Do NOT enable in production unless the route is behind authentication.

ENABLE_DOCS=false
