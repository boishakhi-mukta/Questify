# Questify Backend — Environment Variables
# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ─── Server ───────────────────────────────────────────────
PORT=8000
NODE_ENV=development

# ─── MongoDB Atlas ────────────────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://YOUR_USER:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/questify?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_very_long_random_secret_string
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_different_very_long_random_secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Password Hashing ─────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── Logging ──────────────────────────────────────────────
# Options: combined | dev | short | tiny
LOG_FORMAT=dev
